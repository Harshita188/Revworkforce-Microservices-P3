# RevWorkforce — Required Environment Variables
#
# Copy this file to .env and populate the values before running any service.
# Never commit .env to source control.
#
# ─── Database ────────────────────────────────────────────────────────────────
DB_USERNAME=root
DB_PASSWORD=Hysqlpassword1234

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Must be at least 256 bits (32+ characters) for HMAC-SHA256
JWT_SECRET=revworkforce-super-secure-jwt-secret-key-256-bit-required-2026

# ─── Optional overrides ──────────────────────────────────────────────────────
# JWT_EXPIRATION=86400000   # 24 hours in milliseconds (default)
